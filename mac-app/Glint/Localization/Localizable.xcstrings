    },
    "%@ shortcut could not be registered. Choose another combination from the menu bar." : {
      "comment" : "Status message when a startup shortcut cannot be registered",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ shortcut could not be registered. Choose another combination from the menu bar."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ 快捷键无法注册。请从菜单栏里换一个组合键。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ 快捷鍵無法註冊。請從選單列裡換一個組合鍵。"
          }
        }
      }
    },
    "%@ shortcut was reset to the default because the saved combination could not be registered." : {
      "comment" : "Status message when a saved shortcut falls back to the default value",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ shortcut was reset to the default because the saved combination could not be registered."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "由于已保存的组合键无法注册，%@ 快捷键已重置为默认值。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "由於已儲存的組合鍵無法註冊，%@ 快捷鍵已重設為預設值。"
          }
        }
      }
    },
