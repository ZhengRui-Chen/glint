{
  "sourceLanguage" : "en",
  "strings" : {
    "%@ shortcut could not be registered. Choose another combination from the menu bar." : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "%@ shortcut could not be registered. Choose another combination from the menu bar." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "%@ 快捷键无法注册。请从菜单栏里换一个组合键。" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "%@ 快捷鍵無法註冊。請從選單列裡換一個組合鍵。" } }
      }
    },
    "%@ shortcut was reset to the default because the saved combination could not be registered." : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "%@ shortcut was reset to the default because the saved combination could not be registered." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "由于已保存的组合键无法注册，%@ 快捷键已重置为默认值。" } },
